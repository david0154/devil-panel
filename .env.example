# Devil Panel Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# APPLICATION
# ==========================================
APP_NAME=DevilPanel
APP_ENV=production
APP_PORT=8080
APP_PANEL_PORT=8443
APP_SECRET_KEY=your-super-secret-key-change-this
APP_DEBUG=false

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devilpanel
DB_USER=devilpanel
DB_PASSWORD=strongpasswordhere
DB_SSL_MODE=disable

# ==========================================
# REDIS CACHE
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_DB=0

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# ==========================================
# RABBITMQ QUEUE
# ==========================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=devilpanel
RABBITMQ_PASSWORD=rabbitpassword
RABBITMQ_VHOST=/devilpanel

# ==========================================
# MINIO FILE STORAGE
# ==========================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=devilpanel
MINIO_SECRET_KEY=miniopassword
MINIO_BUCKET=devilpanel-backups
MINIO_USE_SSL=false

# ==========================================
# EMAIL (SMTP)
# ==========================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=emailpassword
SMTP_FROM=Devil Panel <noreply@yourdomain.com>

# ==========================================
# SSL / LET'S ENCRYPT
# ==========================================
LETSENCRYPT_EMAIL=admin@yourdomain.com
ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory

# ==========================================
# DNS
# ==========================================
POWERDNS_API_URL=http://localhost:8053
POWERDNS_API_KEY=powerdns-api-key
DEFAULT_NS1=devil1.yourdomain.com
DEFAULT_NS2=devil2.yourdomain.com

# ==========================================
# AI (LOCAL LLM)
# ==========================================
AI_MODEL=phi3-mini
AI_MODEL_PATH=/opt/devilpanel/models
AI_ENABLED=true
AI_API_PORT=11434
# Download URL for Phi-3 Mini (GGUF format, ~2.2GB)
# AI_MODEL_DOWNLOAD_URL=https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf/resolve/main/Phi-3-mini-4k-instruct-q4.gguf
# Or TinyLlama (~600MB, ultra-light)
# AI_MODEL_DOWNLOAD_URL=https://huggingface.co/TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF/resolve/main/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf

# ==========================================
# BILLING
# ==========================================
STRIPE_API_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
RAZORPAY_KEY_ID=rzp_live_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ==========================================
# MONITORING
# ==========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafanapassword
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ==========================================
# SECURITY
# ==========================================
CSRF_SECRET=csrf-secret-change-this
CORSALLOWED_ORIGINS=https://yourdomain.com
RATE_LIMIT=100
MAX_LOGIN_ATTEMPTS=5
BAN_DURATION=900

# ==========================================
# PANEL DOMAIN
# ==========================================
PANEL_DOMAIN=panel.yourdomain.com
API_DOMAIN=api.yourdomain.com
MONITOR_DOMAIN=monitor.yourdomain.com
